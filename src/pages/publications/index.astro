---
import PageLayout from "../../layouts/Base.astro";
import { Icon } from "astro-icon/components";
import { PaperCard } from "../../components";
import { parseBib } from '../../utils/';
import { publicationTags } from '/src/content/Bibtex/abcpublicationTags'
import Badge from "@/components/Badge.astro";

const meta = {
  description: "my publications",
  title: "publications",
};

const bibModules = import.meta.glob("/src/content/Bibtex/*.bib", {
  query: "?raw",
  import: "default",
  eager: true,
});

const papers = Object.values(bibModules)
  .flatMap((raw) => parseBib(raw as string, publicationTags))
  .sort((a, b) => Number(b.year) - Number(a.year));

const allTags = [...new Set(papers.flatMap(paper => paper.tags))].sort();
---

<PageLayout meta={meta}>
  <h1 class="title mb-6 flex items-center gap-2">
    Publications
    <a class="text-accent-two" href="/rss.xml" target="_blank">
      <span class="sr-only">RSS feed</span>
      <Icon aria-hidden="true" class="h-6 w-6" focusable="false" name="mdi:rss" />
    </a>
  </h1>

  <!-- 搜索框 -->
  <div class="relative mb-8 mx-auto w-full max-w-3xl">
    <input
      id="post-search"
      type="search"
      placeholder="Search ... (click to read abstract)"
      class="flex-1 w-full rounded-xl border border-muted/60 bg-muted/10 py-3 pl-11 pr-4 md:pr-32 xl:pr-48 text-lg
             transition-all duration-200 placeholder:text-muted
             focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
    />
    <svg class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14z" />
    </svg>
    <span id="search-count" class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-sm text-muted"></span>
  </div>

  <!-- 标签栏 -->
  {allTags.length > 0 && (
    <div class="tags-filter mb-6 flex flex-wrap gap-2" id="tag-filter-bar">
      <button type="button" class="tag-filter-btn" data-tag="" aria-label="Show all">
        <Badge variant="large" title="All papers" />
      </button>
      {allTags.map(tag => (
        <button type="button" class="tag-filter-btn" data-tag={tag}>
          <Badge variant="large" title={tag} />
        </button>
      ))}
    </div>
  )}

  <!-- 文献列表容器（用于动态筛选） -->
  <div id="papers-list">
    {papers.map((paper, idx) => (
      <div 
        class="paper-item"
        data-search={[paper.title, paper.authors, paper.abstract, paper.tags.join(' ')].join(' ').toLowerCase()}
        data-tags={paper.tags.join(',')}
        data-year={paper.year}
      >
        <PaperCard {...paper} />
      </div>
    ))}
  </div>
</PageLayout>

<style is:global>
    .tag-filter-btn.active {
      filter: brightness(0.95);
      transform: scale(0.98);
    }
    .paper-item.hidden {
      display: none;
    }
    .tag-filter-btn {
      font-size: 1rem; 
    }
    .tag-filter-btn .badge {
      font-size: 1rem;
    }
</style>

<script>
  const input = document.getElementById('post-search');
  const papersContainer = document.getElementById('papers-list');
  const countSpan = document.getElementById('search-count');
  const tagButtons = document.querySelectorAll('.tag-filter-btn');

  if (papersContainer) {
    const allItems = Array.from(papersContainer.querySelectorAll('.paper-item'));

    // 规范化标签：去除首尾空格，转小写
    function normalizeTag(tag) {
      return (tag || '').trim().toLowerCase();
    }

    // 获取文献的标签数组（规范化后）
    function getItemTags(item) {
      const raw = item.dataset.tags || '';
      return raw.split(',').map(t => normalizeTag(t)).filter(Boolean);
    }

    function updateFilter() {
      const keyword = (input?.value || '').trim().toLowerCase();
      const activeBtn = document.querySelector('.tag-filter-btn.active');
      let activeTagRaw = activeBtn?.dataset.tag || '';
      // 如果是“全部”标签，activeTagRaw 可能为空字符串
      const activeTag = normalizeTag(activeTagRaw);
      
      let visibleCount = 0;

      allItems.forEach(item => {
        const searchText = (item.dataset.search || '').toLowerCase();
        const itemTags = getItemTags(item);

        // 关键词匹配（空格分隔）
        const keywords = keyword ? keyword.split(/\s+/) : [];
        const keywordMatch = keywords.length === 0 || keywords.every(k => searchText.includes(k));
        
        // 标签匹配：activeTag 为空（全部）或 文献标签包含 activeTag
        const tagMatch = activeTag === '' || itemTags.includes(activeTag);

        const shouldShow = keywordMatch && tagMatch;
        
        if (shouldShow) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
        }
      });

      // 调试：打印当前激活的标签和匹配数量（可在控制台查看）
      console.log(`[Filter] activeTag: "${activeTag}", visibleCount: ${visibleCount}`);

      if (countSpan) {
        countSpan.textContent = visibleCount === 0 ? '' : `${visibleCount} papers${visibleCount !== 1 ? 's' : ''}`;
      }
    }

    // 搜索输入事件
    input?.addEventListener('input', updateFilter);

    // 标签点击事件
    tagButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        // 移除所有 active 类
        tagButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // 可选：清空搜索框（如果希望标签筛选时忽略搜索词，取消下面注释）
        // if (input) input.value = '';
        
        updateFilter();
      });
    });

    // 初始化：默认激活“全部”标签（data-tag="" 的那个）
    const defaultBtn = document.querySelector('.tag-filter-btn[data-tag=""]');
    if (defaultBtn && !document.querySelector('.tag-filter-btn.active')) {
      defaultBtn.classList.add('active');
    }
    updateFilter();
  }
</script>