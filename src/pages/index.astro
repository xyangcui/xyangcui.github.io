---
// components
import { type CollectionEntry, getCollection } from "astro:content";
import { Collapse, Icon, Label, Button} from "../components";
import { getAllPosts } from "../content/post/post";
import PageLayout from "../layouts/Base.astro";
import { collectionDateSort } from "../utils/date";
// links
import AmsJournals from '../content/links/AMSjournals.astro'
import AguJournals from '../content/links/AGUjournals.astro'
import SPRJournals from '../content/links/SPRjournals.astro'
// figures
import myfigure from "/public/images/home/avatar.png";
// Posts
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts
	.sort(collectionDateSort)
	.slice(0, MAX_POSTS) as CollectionEntry<"post">[];

// Notes
const MAX_NOTES = 2;
const allNotes = await getCollection("note");
const latestNotes = allNotes.sort(collectionDateSort).slice(0, MAX_NOTES);
---

<PageLayout meta={{ title: "Home" }}>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
        <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
            <div class='flex flex-col items-center gap-8 sm:flex-row sm:items-start'>
                <figure class='shrink-0'>
                    <img
                        src={myfigure.src}
                        alt='Profile'
                        style={{ width: "clamp(250px, 15vw, 400px)", height: "auto" }}
                        class='rounded-xl border-0 shadow-lg'
                    />
                </figure>

                <div class='flex flex-col items-center gap-y-4 text-center sm:items-start sm:text-left'>
                    <h1 class='text-3xl font-medium'>Hi, I'm Xiangyang Cui.</h1>
                    <p class='text-muted-foreground'>
                        Lorem ipsum dolor sit amet, vidit suscipit at mei. Quem denique mea id. Usu ei
                        regione indoctum dissentiunt, cu meliore fuisset mei, vel quod voluptua ne. Ex
                        dicat impedit mel, at eum oratio possit voluptatum.
                    </p>

                    <div class='flex flex-wrap justify-center gap-x-7 gap-y-3 sm:justify-start'>
                        <Label title='ORCID' as='a' href='https://orcid.org/0009-0006-8639-4400' target='_blank'>
                            <Icon name='orcid' class='size-5' slot='icon' color='#A6CE39' />
                        </Label>
                        <Label title='Github' as='a' href='https://github.com/xyangcui' target='_blank'>
                            <Icon name='github' class='size-5' slot='icon' />
                        </Label>
                    </div>
                </div>
            </div>
        </div>
    </section>

	<div class="space-y-3">
        <Collapse title='Featured projects' class='text-2xl font-bold rounded-xl p-2'>
        </Collapse>
        <Collapse title='Featured publications' class='text-2xl font-bold rounded-xl p-2'>
        <ol style="list-style-type: decimal; padding-left: 1.5rem; font-size: 16px; font-weight: 500">
          <li><p class="text-base leading-relaxed text-base-content dark:text-base-content"> <span class="font-bold">Cui, X.</span>, B. Zhu, and B. Sun, 2023: 
        Influence of three types of boreal summer intraseasonal oscillation on summer precipitation over the Yangtze River Valley. 
        <span class="italic font-semibold">Atmospheric and Oceanic Science Letters</span>, 16, 100394,
        <a href="https://doi.org/10.1016/j.aosl.2023.100394" class="text-blue-500 hover:underline" target="_blank">DOI</a>. </p></li>
        <li> <p class="text-base leading-relaxed text-base-content dark:text-base-content"> 123</p></li>
        </ol>
        </Collapse>
        <Collapse title='Friendly Links' class='text-2xl font-bold rounded-xl p-2'>
          <h2>
          <Collapse title="American Meteorological Society Journals" class='text-xl font-bold rounded-xl p-2'>
            <div class="text-base"><AmsJournals /></div>
          </Collapse>
          <Collapse title="American Geophysical Union Journals" class='text-xl font-bold rounded-xl p-2'>
            <div class="text-base"><AguJournals /></div>
          </Collapse>
          <Collapse title="Springer Nature Journals" class='text-xl font-bold rounded-xl p-2'>
            <div class="text-base"><SPRJournals /></div>
          </Collapse>
          </h2>
        </Collapse>
    </div>
</PageLayout>
