---
import PagefindConfig from "astro-pagefind/components/PagefindConfig.astro";
import { Icon } from "astro-icon/components";
---

<PagefindConfig />

<div id="search-inline" class="search-inline">
	<div id="search-panel" class="search-panel">
		<pagefind-searchbox></pagefind-searchbox>
	</div>

	<button
		id="search-toggle"
		class="search-toggle flex h-8 w-8 items-center justify-center rounded-lg drop-shadow-[0px_1.5px_1.5px_rgba(0,0,0,0.175)] hover:text-accent-two"
		aria-label="Open search"
	>
		<Icon
			aria-hidden="true"
			class="h-6 w-6"
			focusable="false"
			name="hugeicons:search-01"
		/>
	</button>
</div>

<script>
	const root = document.getElementById("search-inline");
	const toggle = document.getElementById("search-toggle");
	const panel = document.getElementById("search-panel");

	function openSearch() {
		panel?.classList.add("is-open");

		setTimeout(() => {
			panel?.querySelector("input")?.focus();
		}, 80);
	}

	function closeSearch() {
		panel?.classList.remove("is-open");
	}

	toggle?.addEventListener("click", (e) => {
		e.stopPropagation();

		if (panel?.classList.contains("is-open")) {
			closeSearch();
		} else {
			openSearch();
		}
	});

	document.addEventListener("click", (e) => {
		const target = e.target;
		if (!(target instanceof Node)) return;

		if (root && !root.contains(target)) {
			closeSearch();
		}
	});

	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") closeSearch();
	});
</script>

<style is:global>
	.search-inline {
		position: relative;
		display: flex;
		align-items: center;
		z-index: 9999;
	}

	.search-toggle {
		position: relative;
		z-index: 2;
		border: none;
		background: transparent;
		cursor: pointer;
	}

	.search-panel {
		position: absolute;
		top: 50%;
		right: 2.5rem;

		width: 0;
		opacity: 0;
		overflow: hidden;

		transform: translateY(-50%);
		transition:
			width 0.22s ease,
			opacity 0.18s ease;

		z-index: 1;
	}

	.search-panel.is-open {
		width: 320px;
		opacity: 1;
		overflow: visible;
	}

	.search-panel pagefind-searchbox {
		display: block;
		width: 320px;
	}

	.search-panel .pagefind-ui {
		width: 100% !important;
		padding: 0 !important;
		font-family: inherit;
	}

	.search-panel .pagefind-ui__form {
		width: 100% !important;
		margin: 0 !important;
	}

	.search-panel .pagefind-ui__search-input {
		width: 100% !important;
		height: 2rem !important;
		box-sizing: border-box !important;

		border: none !important;
		border-radius: 0.5rem !important;

		background: theme("colors.color.100") !important;
		color: theme("colors.textColor") !important;

		font-size: 0.875rem !important;
		padding: 0 2.25rem 0 2.25rem !important;

		outline: none !important;
	}

	.search-panel .pagefind-ui__search-clear {
		top: 0 !important;
		right: 0 !important;

		width: 2rem !important;
		height: 2rem !important;
		padding: 0 !important;

		background: transparent !important;
		border: none !important;
	}

	.search-panel .pagefind-ui__drawer {
		position: absolute !important;

		top: calc(100% + 0.75rem) !important;
		right: 0 !important;

		width: 520px !important;
		max-height: 70vh !important;
		overflow-y: auto !important;

		padding: 1rem !important;

		border-radius: 1rem !important;
		background: theme("colors.bgColor") !important;

		box-shadow:
			0 20px 60px rgba(0, 0, 0, 0.18),
			0 8px 24px rgba(0, 0, 0, 0.12) !important;
	}

	.search-panel .pagefind-ui__result {
		border: none !important;
		padding: 0 0 1.25rem 0 !important;
	}

	.search-panel .pagefind-ui__result-link {
		color: theme("colors.accent-base") !important;
		font-weight: 600 !important;
		text-decoration: none !important;
	}

	.search-panel .pagefind-ui__result-excerpt {
		color: theme("colors.textColor") !important;
		font-size: 0.875rem !important;
		line-height: 1.6 !important;
	}

	.search-panel mark {
		background: transparent !important;
		color: theme("colors.accent-two") !important;
		font-weight: 700;
	}

	@media (max-width: 768px) {
		.search-panel.is-open {
			width: 220px;
		}

		.search-panel pagefind-searchbox {
			width: 220px;
		}

		.search-panel .pagefind-ui__drawer {
			position: fixed !important;
			top: 4.5rem !important;
			left: 1rem !important;
			right: 1rem !important;

			width: auto !important;
			max-height: 70vh !important;
		}
	}
</style>