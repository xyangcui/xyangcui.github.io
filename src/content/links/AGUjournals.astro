---
import { agujournals } from './journals'
---

<div class='flex flex-col gap-y-2'>
  {
    agujournals.map((journal) => (
      <a
        href={journal.url}
        target='_blank'
        rel='noopener noreferrer'
        class='underline underline-offset-4'
      >
        {journal.title}
      </a>
    ))
  }
</div>